<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo Completo Herbalife Colombia 2026</title>
    <style>
        :root {
            --primary: #2e7d32;
            --primary-light: #4caf50;
            --dark: #212121;
            --gray: #666;
            --light-bg: #f5f5f5;
            --white: #ffffff;
            --shadow: 0 10px 30px rgba(0,0,0,0.06);
            --photoroom-shadow: drop-shadow(0 15px 12px rgba(0,0,0,0.15));
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Arial, sans-serif;
        }

        body {
            background-color: var(--light-bg);
            color: var(--dark);
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
            padding: 20px 0;
        }

        header h1 {
            color: var(--primary);
            font-size: 2.3rem;
            margin-bottom: 8px;
        }

        header p {
            color: var(--gray);
            font-size: 1rem;
        }

        .category-title {
            font-size: 1.5rem;
            color: var(--dark);
            margin: 40px 0 20px 0;
            padding-left: 12px;
            border-left: 6px solid var(--primary);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        .card {
            background: var(--white);
            border-radius: 14px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: transform 0.25s ease;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border: 1px solid rgba(0,0,0,0.02);
        }

        .card:hover {
            transform: translateY(-4px);
        }

        /* Contenedor Efecto Estudio PhotoRoom */
        .img-container {
            background: #ffffff;
            padding: 25px;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 220px;
            position: relative;
        }

        .img-container svg {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            filter: var(--photoroom-shadow);
        }

        .badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--primary);
            color: var(--white);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        .info {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .info h3 {
            font-size: 1.1rem;
            margin-bottom: 6px;
            color: var(--dark);
        }

        .info p {
            font-size: 0.85rem;
            color: var(--gray);
            line-height: 1.4;
            margin-bottom: 12px;
        }

        .price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
            padding-top: 12px;
            border-top: 1px solid #f2f2f2;
        }

        .price {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
        }

        .btn-add {
            background: var(--primary);
            color: var(--white);
            border: none;
            padding: 8px 14px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background 0.2s ease;
        }

        .btn-add:hover {
            background: var(--primary-light);
        }

        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Catálogo de Nutrición Oficial</h1>
        <p>Línea Completa Expandida — Precios de Mercado 2026 en COP (Colombia)</p>
    </header>

    <!-- NUTRICIÓN BÁSICA -->
    <div class="category-title">Nutrición Básica y Control de Peso</div>
    <div class="grid">
        
        <div class="card">
            <div class="img-container">
                <span class="badge">Esencial</span>
                <svg viewBox="0 0 100 150" width="90">
                    <rect x="25" y="30" width="50" height="110" rx="8" fill="#e8f5e9"/>
                    <rect x="23" y="20" width="54" height="15" rx="4" fill="#2e7d32"/>
                    <rect x="30" y="55" width="40" height="55" fill="#ffffff" rx="2"/>
                    <text x="50" y="123" font-size="7" font-weight="bold" fill="#2e7d32" text-anchor="middle">FÓRMULA 1</text>
                </svg>
            </div>
            <div class="info">
                <div>
                    <h3>Fórmula 1 Batido Nutricional</h3>
                    <p>Sustituto de comida con proteínas, fibra soluble y 21 vitaminas esenciales.</p>
                </div>
                <div class="price-row">
                    <div class="price">$142.000 COP</div>
                    <button class="btn-add">Añadir 🛒</button>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="img-container">
                <svg viewBox="0 0 100 150" width="90">
                    <rect x="20" y="40" width="60" height="100" rx="10" fill="#fff3e0"/>
                    <rect x="18" y="28" width="64" height="16" rx="5" fill="#f57c00"/>
                    <rect x="26" y="60" width="48" height="50" fill="#ffffff" rx="2"/>
                    <text x="50" y="125" font-size="8" font-weight="bold" fill="#f57c00" text-anchor="middle">PROTEIN PDM</text>
                </svg>
            </div>
            <div class="info">
                <div>
                    <h3>Protein Drink Mix (PDM)</h3>
                    <p>Refuerzo proteico intermedio ideal para saciar el apetito y proteger el músculo.</p>
                </div>
                <div class="price-row">
                    <div class="price">$174.000 COP</div>
                    <button class="btn-add">Añadir 🛒</button>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="img-container">
                <svg viewBox="0 0 100 150" width="90">
                    <rect x="28" y="45" width="44" height="95" rx="6" fill="#f3e5f5"/>
                    <rect x="26" y="35" width="48" height="12" rx="3" fill="#7b1fa2"/>
                    <rect x="33" y="60" width="34" height="50" fill="#ffffff" rx="2"/>
                    <text x="50" y="123" font-size="8" font-weight="bold" fill="#7b1fa2" text-anchor="middle">PPP</text>
                </svg>
            </div>
            <div class="info">
                <div>
                    <h3>Polvo de Proteína Personalizado</h3>
                    <p>Combinación pura de soya y suero de leche libre de grasas y carbohidratos.</p>
                </div>
                <div class="price-row">
                    <div class="price">$119.000 COP</div>
                    <button class="btn-add">Añadir 🛒</button>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="img-container">
                <svg viewBox="0 0 100 150" width="90">
                    <rect x="25" y="40" width="50" height="100" rx="8" fill="#e1f5fe"/>
                    <rect x="23" y="28" width="54" height="14" rx="4" fill="#0288d1"/>
                    <rect x="31" y="58" width="38" height="52" fill="#ffffff" rx="2"/>
                    <text x="50" y="124" font-size="7" font-weight="bold" fill="#0288d1" text-anchor="middle">COMPLEJO VIT</text>
                </svg>
            </div>
            <div class="info">
                <div>
                    <h3>Fórmula 2 Complejo Multivitamínico</h3>
                    <p>Aporta más de 20 vitaminas y minerales esenciales para la defensa celular del cuerpo.</p>
                </div>
                <div class="price-row">
                    <div class="price">$98.000 COP</div>
                    <button class="btn-add">Añadir 🛒</button>
                </div>
            </div>
        </div>
    </div>

    <!-- BIENESTAR DIGESTIVO -->
    <div class="category-title">Bienestar Digestivo y Salud Intestinal</div>
    <div class="grid">
        
        <div class="card">
            <div class="img-container">
                <span class="badge">Popular</span>
                <svg viewBox="0 0 100 150" width="90">
                    <rect x="32" y="35" width="36" height="105" rx="5" fill="#e8f5e9"/>
                    <rect x="30" y="25" width="40" height="12" rx="3" fill="#1b5e20"/>
                    <text x="50" y="122" font-size="8" font-weight="bold" fill="#1b5e20" text-anchor="middle">ALOE</text>
                </svg>
            </div>
            <div class="info">
                <div>
                    <h3>Herbal Aloe Concentrado</h3>
                    <p>Bebida refrescante de sábila que limpia y alivia el tracto digestivo interno.</p>
                </div>
                <div class="price-row">
                    <div class="price">$136.000 COP</div>
                    <button class="btn-add">Añadir 🛒</button>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="img-container">
                <svg viewBox="0 0 100 150" width="90">
